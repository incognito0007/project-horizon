# ============================================================
#  Project Horizon — Root .gitignore
#  Covers: Java · C# / .NET · React / Next.js / TypeScript
#  IDEs:   IntelliJ · VS Code · Visual Studio
# ============================================================


# ============================================================
#  JAVA / MAVEN
# ============================================================
target/
*.class
*.jar
*.war
*.ear
*.nar
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar


# ============================================================
#  C# / .NET
# ============================================================
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.nupkg
*.snupkg
*.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/
TestResults/
coverage/
*.trx
*.coveragexml
*.coverage
*.opencover.xml
*.[Cc]ache
!*.[Cc]ache/


# ============================================================
#  NODE / REACT / NEXT.JS / TYPESCRIPT
# ============================================================
node_modules/
.next/
out/
dist/
build/
.turbo/
.vercel/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Storybook build output
storybook-static/


